    "google-auth-library": "^10.7.0",
    "groq-sdk": "^1.2.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "lucide-react": "^1.18.0",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.11",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
